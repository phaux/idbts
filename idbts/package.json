{
  "name": "idbts",
  "version": "0.1.0",
  "description": "Typed IndexedDB wrapper",
  "license": "ISC",
  "author": "phaux",
  "type": "module",
  "exports": {
    ".": {
      "idbts/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "prepare": "tsc -p tsconfig.build.json",
    "clean": "rm -r dist",
    "check": "tsc --noEmit",
    "test": "node --test --import ./test/test.env.ts --test-reporter spec --test-reporter-destination stdout --experimental-test-coverage --test-reporter lcov --test-reporter-destination lcov.info --test-timeout 3000"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "expect-type": "^1.3.0",
    "fake-indexeddb": "^6.2.5"
  }
}
