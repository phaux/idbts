{
  "name": "idbts",
  "version": "0.1.0",
  "description": "Typed IndexedDB wrapper",
  "keywords": [
    "database",
    "indexeddb"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaux/idbts.git",
    "directory": "idbts"
  },
  "license": "MIT",
  "author": "phaux",
  "type": "module",
  "exports": {
    ".": {
      "idbts/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "clean": "rm -r dist",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "node --test --import ./test/test.env.ts --test-reporter spec --test-reporter-destination stdout --experimental-test-coverage --test-reporter lcov --test-reporter-destination lcov.info --test-timeout 3000"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "expect-type": "^1.3.0",
    "fake-indexeddb": "^6.2.5",
    "zod": "^4.4.3"
  }
}
