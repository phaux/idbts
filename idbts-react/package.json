{
  "name": "idbts-react",
  "version": "0.1.0",
  "description": "Typed IndexedDB wrapper for React",
  "keywords": [
    "database",
    "indexeddb",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaux/idbts.git",
    "directory": "idbts-react"
  },
  "license": "MIT",
  "author": "phaux",
  "type": "module",
  "exports": {
    ".": {
      "idbts/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "clean": "rm -r dist",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "node --test --experimental-default-config-file --experimental-test-coverage --test-timeout 5000"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "idbts": "*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "peerDependencies": {
    "idbts": "*",
    "react": "*"
  }
}
